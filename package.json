{
  "name": "dockhub",
  "version": "0.1.5",
  "private": true,
  "description": "DockHub - a convenient, GitLab-backed Docker Swarm management console",
  "author": "Seng Phirum <sengphirum143@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "dev:swarm": "node scripts/dev-swarm.mjs",
    "dev:swarm:full": "node scripts/dev-swarm.mjs --profile full up --build",
    "dev:swarm:down": "node scripts/dev-swarm.mjs down",
    "dev:swarm:reset": "node scripts/dev-swarm.mjs down -v",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "build:docs": "NUXT_STATIC_DOCS=true nuxt generate",
    "preview:docs": "npx serve .output/public",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/icon": "^1.10.3",
    "@nuxt/ui": "^4.8.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/nuxt": "^13.1.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.10.0",
    "dockerode": "^5.0.0",
    "jose": "^6.0.11",
    "ldapts": "^8.1.8",
    "lowdb": "^7.0.1",
    "nanoid": "^5.1.5",
    "nuxt": "^4.4.7",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1"
  }
}
