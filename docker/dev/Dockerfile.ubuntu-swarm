# syntax=docker/dockerfile:1.7

# Historical filename; the manager uses Debian slim so Nuxt/native packages can
# use glibc prebuilds. Workers stay on the much smaller docker:dind image.
FROM node:22-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive
ARG NPM_CONFIG_STRICT_SSL=false
ENV NPM_CONFIG_STRICT_SSL=${NPM_CONFIG_STRICT_SSL}
ENV npm_config_strict_ssl=${NPM_CONFIG_STRICT_SSL}
ARG NODE_TLS_REJECT_UNAUTHORIZED=0
ENV NODE_TLS_REJECT_UNAUTHORIZED=${NODE_TLS_REJECT_UNAUTHORIZED}
ENV DOCKER_TLS_CERTDIR=""

SHELL ["/bin/sh", "-c"]

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    docker.io \
    g++ \
    iproute2 \
    iptables \
    make \
    netcat-openbsd \
    python3 \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/* \
  && node --version \
  && npm --version \
  && docker --version \
  && dockerd --version

WORKDIR /workspace

COPY docker/dev/swarm-entrypoint.sh /usr/local/bin/dockhub-swarm-dev
RUN chmod +x /usr/local/bin/dockhub-swarm-dev

EXPOSE 3000 2375 2377 7946 4789

ENTRYPOINT ["/bin/sh", "/usr/local/bin/dockhub-swarm-dev"]
CMD ["manager"]
