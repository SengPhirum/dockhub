# KNetraHub-Net-API configuration - independent of the portal's own .env

# Must exactly match the KNetraHub portal's NUXT_JWT_SECRET. This is what
# lets this API verify a token the portal issued, with no shared database
# and no callback to the portal on every request.
NUXT_NET_JWT_SECRET=change-me-to-a-long-random-string

# Own database connection (Option A: same shared Postgres/TimescaleDB
# instance as the portal is fine, as long as everything lives under the
# `net` schema - this service never touches the portal's own tables).
NUXT_NET_DB_HOST=localhost
NUXT_NET_DB_PORT=5432
NUXT_NET_DB_NAME=knetrahub
NUXT_NET_DB_USER=knetrahub
NUXT_NET_DB_PASSWORD=knetrahub
NUXT_NET_DB_SSL=false
NUXT_NET_DB_POOL_MAX=5

PORT=4101
